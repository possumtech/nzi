# NZI environment configuration

# Select the model alias to use (from lua/nzi/config.lua)
# Options: coder, local_coder
NZI_MODEL=coder

# Referer URL for OpenRouter/OpenAI alignment
NZI_REFERER=https://github.com/possumtech/nzi

# Coder Model Settings
# NZI_CODER_MODEL=qwen/qwen-2.5-coder-32b-instruct
# NZI_CODER_BASE=https://openrouter.ai/api/v1

# Local Model Settings
# NZI_LOCAL_MODEL=qwen2.5-coder:latest
# NZI_LOCAL_BASE=http://localhost:11434/v1

# Ecosystem Settings
# Path to python executable (e.g., .venv/bin/python)
# NZI_PYTHON_CMD=python3

# API Keys
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENAI_API_KEY=your_openai_key_here

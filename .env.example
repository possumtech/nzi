# nzi environment configuration
# Target your local model provider (e.g., Ollama via LiteLLM)
NZI_TEST_LOCAL=http://192.168.1.17:11434

# The default model to address (use provider/name format for LiteLLM)
NZI_DEFAULT_MODEL=ollama/qwenzel

# API Key if required by your provider
# NZI_API_KEY=your_key_here
